{
  "name": "@proticom/paperboy-cli",
  "version": "0.2.1",
  "description": "Paperboy document-to-markdown converter and CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "paperboy-cli": "./dist/cli.js",
    "paperboy-dispatch": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./converter": "./dist/converter.js",
    "./config": "./dist/config.js",
    "./setup": "./dist/setup.js",
    "./doctor": "./dist/doctor.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "doctor": "node ./dist/cli.js doctor",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "npm run build && vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@proticom/paperboy-converter": "file:../paperboy-converter",
    "@inquirer/prompts": "^7.8.4",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
