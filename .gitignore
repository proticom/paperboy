# Gnosys project store (local)
.gnosys/

# Marketing site: separate private repo (nested clone lives at ./paperboy-site/)
paperboy-site/

# Dependencies
**/node_modules/

# Builds & caches
**/dist/
**/.next/
**/out/
**/coverage/
**/.vercel/
**/*.tsbuildinfo
next-env.d.ts

# Rust / Tauri
**/target/

# OS / editor
.DS_Store

# Claude Code local permission cache (per-machine, not shared)
.claude/settings.local.json
# SMB filesystem leftover markers (Synology NAS share)
**/.smbdelete*
# Synology / macOS finder duplicates
**/* [0-9].js
**/* [0-9].ts

# Paperboy CLI doctor probe leftovers (cleaned up on success; failures may litter cwd)
**/.paperboy-doctor-*.tmp

# Env & secrets
**/.env
**/.env.*
!.env.example

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Optional: packed converter tarball (rebuild with npm pack in paperboy-converter)
*.tgz

# project-status-dashboard skill outputs
project-status-dashboard.html
project-status-dashboard.data.json
