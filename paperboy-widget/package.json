{
  "name": "@proticom/paperboy-widget",
  "version": "0.1.0",
  "description": "Embeddable web/markdown toggle widget — converts any page to Markdown with one click.",
  "main": "dist/paperboy-widget.min.js",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "markdown",
    "widget",
    "paperboy",
