    "turndown",
    "embeddable"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proticom/paperboy.git",
    "directory": "paperboy-widget"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@proticom/paperboy-converter": "file:../paperboy-converter"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "vitest": "^3.2.4"
  }
