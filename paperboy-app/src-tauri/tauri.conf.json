{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paperboy",
  "version": "0.1.0",
  "identifier": "run.paperboy.editor",
  "build": {
    "beforeDevCommand": "node scripts/dev-server.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Paperboy",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 17
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
